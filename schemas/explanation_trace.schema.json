{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wjx.local/schemas/explanation_trace.schema.json",
  "title": "WJX Explanation Trace",
  "description": "Provides a replayable white-box path from input data and evidence to the final result.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "run_id",
    "module_id",
    "step_id",
    "input_references",
    "transformation",
    "output_reference"
  ],
  "properties": {
    "trace_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "module_id": {"type": "string", "minLength": 1},
    "step_id": {"type": "string", "minLength": 1},
    "input_references": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "transformation": {"type": "string", "minLength": 1},
    "formula": {"type": ["string", "null"]},
    "parameter_values": {"type": "object"},
    "intermediate_values": {"type": "object"},
    "output_reference": {"type": "string", "minLength": 1},
    "code_reference": {"type": ["string", "null"]},
    "test_reference": {"type": ["string", "null"]},
    "evidence_reference": {"type": ["string", "null"]},
    "warning_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
  }
}

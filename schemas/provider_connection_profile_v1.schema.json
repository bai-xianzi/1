{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wjx://schemas/provider_connection_profile_v1",
  "title": "Provider connection profile without secret material",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "provider_id",
    "connection_id",
    "status",
    "public_configuration",
    "credential_references",
    "official_authorization_confirmed",
    "read_only_entitlement_confirmed",
    "execution_domain_isolated"
  ],
  "properties": {
    "provider_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{1,63}$"
    },
    "connection_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{1,63}$"
    },
    "status": {
      "type": "string"
    },
    "public_configuration": {
      "type": "object"
    },
    "credential_references": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "official_authorization_confirmed": {
      "type": "boolean"
    },
    "read_only_entitlement_confirmed": {
      "type": "boolean"
    },
    "execution_domain_isolated": {
      "type": "boolean"
    }
  },
  "not": {
    "anyOf": [
      {
        "required": [
          "password"
        ]
      },
      {
        "required": [
          "api_key"
        ]
      },
      {
        "required": [
          "api_secret"
        ]
      },
      {
        "required": [
          "token"
        ]
      },
      {
        "required": [
          "secret_value"
        ]
      }
    ]
  }
}

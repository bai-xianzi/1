{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wjx.local/schemas/windows_credential_reference_v1.schema.json",
  "title": "WJX Windows Credential Reference",
  "description": "Secret-free reference and B2C status contract for one provider credential stored in Windows Credential Manager.",
  "type": "object",
  "additionalProperties": false,
  "required": ["backend", "reference", "configured", "secret_value"],
  "properties": {
    "backend": {
      "const": "WINDOWS_CREDENTIAL_MANAGER"
    },
    "reference": {
      "type": "string",
      "pattern": "^windows-credential://WJX/provider/[a-z][a-z0-9_]{1,63}/[a-z][a-z0-9_]{1,63}/[a-z][a-z0-9_]{1,63}$"
    },
    "configured": {
      "type": "boolean"
    },
    "secret_value": {
      "type": "null",
      "description": "The B2C status response never returns secret material."
    }
  }
}
